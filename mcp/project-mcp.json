{
  "mcpServers": {
    "sentrux": {
      "type": "stdio",
      "command": "sentrux",
      "args": ["--mcp"],
      "env": {}
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://127.0.0.1:9222"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--viewport-size=1440,900"
      ]
    }
  }
}
