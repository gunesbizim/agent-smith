{
  "mcpServers": {
    "gitnexus": {
      "type": "stdio",
      "command": "gitnexus",
      "args": ["mcp"],
      "env": {}
    },
    "git-memory": {
      "type": "stdio",
      "command": "git-memory",
      "args": ["serve"],
      "env": {}
    },
    "serena": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "%USERPROFILE%\\.serena\\venv\\Scripts\\serena.exe",
        "start-mcp-server",
        "--project-from-cwd"
      ],
      "env": {}
    }
  },
  "permissions": {
    "allow": [
      "mcp__ouroboros__ouroboros_pm_interview"
    ]
  }
}
