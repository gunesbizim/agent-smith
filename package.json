{
  "name": "agent-smith",
  "version": "0.2.1",
  "description": "Autonomous development pipeline — MCP auto-config, project-aware skill stubs, Jira-to-PR automation, Playwright+Obsidian docs",
  "keywords": [
    "claude-code",
    "mcp",
    "skills",
    "autonomous",
    "pipeline",
    "jira",
    "playwright",
    "obsidian",
    "pr-automation",
    "code-review",
    "documentation",
    "smithery"
  ],
  "license": "MIT",
  "author": "Agent Smith Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/gunesbizim/agent-smith"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-smith": "./bin/agent-smith.js"
  },
  "files": [
    "dist/",
    "templates/",
    "hooks/",
    "bin/",
    "smithery.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node bin/agent-smith.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov",
    "sonarqube": "npx sonarqube-scanner -Dsonar.token=${SONAR_TOKEN:-} -Dsonar.host.url=${SONAR_HOST_URL:-http://localhost:9000}",
    "sonarqube:start": "docker compose -f sonarqube/docker-compose.yml up -d",
    "sonarqube:stop": "docker compose -f sonarqube/docker-compose.yml down",
    "sonarqube:setup": "bash sonarqube/setup.sh"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "semver": "^7.6.0",
    "tinyglobby": "^0.2.17",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.19.42",
    "@types/semver": "^7.7.1",
    "@types/which": "^3.0.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
