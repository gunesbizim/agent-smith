{
  "mcpServers": {
    "gitnexus": {
      "type": "stdio",
      "command": "gitnexus",
      "args": ["mcp"],
      "env": {}
    },
    "git-memory": {
      "type": "stdio",
      "command": "git-memory",
      "args": ["serve"],
      "env": {}
    }
  },
  "permissions": {
    "allow": [
      "mcp__ouroboros__ouroboros_pm_interview"
    ]
  }
}
